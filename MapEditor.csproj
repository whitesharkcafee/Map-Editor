<?xml version="1.0" encoding="utf-8"?>
<!--
  ===========================================================================================
  Ready-to-build Fractal Space mod project. References (almost) every game DLL up front, so most
  Unity / game APIs are available without you having to add references by hand.

  PATH TO THE GAME DLLs ($(GameManaged)):
    Defaults to "..\Fractal_Space_Data\Managed" - correct when this folder ships INSIDE your
    Fractal Space game folder (next to the .exe). To build from elsewhere, set GameManaged via a
    Directory.Build.props next to this file, or:  dotnet build -p:GameManaged="C:\...\Managed"

  TO BUILD:  open in Visual Studio and Build (F6), or run "dotnet build" here.
  Output:    bin\Debug\ModSample.dll  ->  copy into your Mods folder:
             %USERPROFILE%\AppData\LocalLow\Haze Games\Fractal Space MOD\Mods\
  ===========================================================================================
-->
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <OutputType>Library</OutputType>
    <RootNamespace>MapEditor</RootNamespace>
    <AssemblyName>MapEditor</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <!-- Compile against UNITY's mscorlib (referenced below), NOT .NET Framework's, so
         System.ReadOnlySpan<T> and other Unity 6 API types resolve against the game's DLLs. -->
    <NoStdLib>true</NoStdLib>
    <GameManaged Condition=" '$(GameManaged)' == '' ">..\Fractal_Space_Data\Managed</GameManaged>
    <!-- Where the GAME'S gameplay code (Assembly-CSharp.dll) is referenced from. Defaults to the
         installed game's Managed folder. If you have the Unity project, override this in your
         Directory.Build.props to "<UnityProjectRoot>\Library\ScriptAssemblies" - the editor recompiles
         Assembly-CSharp.dll there on every code change, so you can build mods against the LATEST game
         code without making a standalone build first. (Engine / 3rd-party DLLs still come from
         $(GameManaged) - they don't change between editor and build.) -->
    <GameScripts Condition=" '$(GameScripts)' == '' ">$(GameManaged)</GameScripts>
    <!-- Auto-derive the game's install root and .exe FROM $(GameManaged), so you only ever set that one
         path. The Managed folder is two levels under the install root (<Game>\Fractal_Space_Data\Managed),
         so the root is GameManaged\..\.. and the .exe sits in it. Combine+GetFullPath handles BOTH the
         relative default above and an absolute GameManaged override, anchored to this project's folder. -->
    <GameRoot>$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(GameManaged)', '..', '..'))))</GameRoot>
    <GameExe>$(GameRoot)\Fractal_Space.exe</GameExe>
    <!-- Makes F5 / the green "Start" button launch the game directly (Debug > Start Program). LAUNCH-ONLY:
         it does NOT affect Build (Ctrl+Shift+B) at all, and a wrong path only fails the launch, never the
         build. If you change it via Project Properties > Debug, VS writes a local .csproj.user that wins. -->
    <StartAction>Program</StartAction>
    <StartProgram>$(GameExe)</StartProgram>
    <StartWorkingDirectory>$(GameRoot)</StartWorkingDirectory>
    <!-- Build the mod DLL STRAIGHT into the game's Mods folder, so you can build and immediately run
         the game (no manual copy). This is the modding build's persistent-data path. Because every
         <Reference> has Private=False, ONLY ModSample.dll (+ .pdb) land here - not the dependencies.
         To output beside the project instead, set this to bin\Debug\. -->
    <OutputPath Condition=" '$(OutputPath)' == '' ">$(USERPROFILE)\AppData\LocalLow\Haze Games\Fractal Space MOD\Mods\</OutputPath>
    <!-- No .pdb - a mod doesn't need debug symbols shipped into the Mods folder. -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <ProjectGuid>{340F163F-4D3C-BA8B-B363-93CF1A0450F3}</ProjectGuid>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <Optimize>true</Optimize>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
