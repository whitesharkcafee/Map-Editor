using System;
using System.Collections.Generic;
using System.Linq;
using UnityEngine;

// Mono-friendly NGUI helper toolkit for mods.
//
// This is NOT a copy of any specific mod's code — it's a generic re-implementation
// of the common patterns modders use to manipulate an existing game's NGUI UI
// (cloning button templates, wiring click/toggle/input events, fading things
// in/out, dragging windows, building simple popups) written for a Mono (not IL2CPP)
// mod loader, so no Il2Cpp interop / IntPtr constructors are needed.
//
// IMPORTANT — you MUST call NGUIModHelper.Setup(...) once (e.g. when your main
// menu scene loads) and hand it references to an existing button/toggle/input/panel
// in the game's own UI to use as clone templates. Every game's NGUI prefabs are
// laid out differently, so also wire up the *Cleanup hooks to strip out whatever
// game-specific scripts (custom ButtonController-type classes, localization
// components, etc.) get dragged along when you Instantiate() the template.

namespace YourMod.UI
{
    #region Extension methods

    /// <summary>
    /// Small GameObject/Transform helpers that make digging through NGUI's
    /// (often deeply nested) widget hierarchies bearable.
    /// </summary>
    public static class NGUIGameObjectExtensions
    {
        /// <summary>
        /// Searches all descendants for a child with an exact name match, checking
        /// shallower levels first (breadth-first) — this matters because some
        /// templates have both a top-level "Label" and a nested "Background/Label",
        /// and a naive depth-first search can return the wrong one depending on
        /// sibling order.
        /// </summary>
        public static GameObject GetChild(this GameObject go, string name)
        {
            if (go == null) return null;

            var queue = new Queue<Transform>();
            queue.Enqueue(go.transform);

            while (queue.Count > 0)
            {
                var t = queue.Dequeue();
                for (int i = 0; i < t.childCount; i++)
                {
                    var child = t.GetChild(i);
                    if (child.name == name) return child.gameObject;
                    queue.Enqueue(child);
                }
            }
            return null;
        }

        /// <summary>Navigates an explicit slash-separated path, e.g. "Background/Label".</summary>
        public static GameObject GetChildAt(this GameObject go, string path)
        {
            if (go == null) return null;
            var t = go.transform.Find(path);
            return t != null ? t.gameObject : null;
        }

        /// <summary>Returns the immediate (direct) children only.</summary>
        public static List<GameObject> GetChilds(this GameObject go)
        {
            var result = new List<GameObject>();
            if (go == null) return result;

            var t = go.transform;
            for (int i = 0; i < t.childCount; i++)
                result.Add(t.GetChild(i).gameObject);

            return result;
        }

        public static void DisableAllChildren(this GameObject go)
        {
            foreach (var child in go.GetChilds())
                child.SetActive(false);
        }

        public static void EnableAllChildren(this GameObject go)
        {
            foreach (var child in go.GetChilds())
                child.SetActive(true);
        }

        /// <summary>Destroys every immediate child GameObject (not the object itself).</summary>
        public static void DeleteAllChildren(this GameObject go)
        {
            foreach (var child in go.GetChilds())
                UnityEngine.Object.Destroy(child);
        }

        /// <summary>Safely destroys a component if it exists; no-op otherwise.</summary>
        public static void RemoveComponent<T>(this GameObject go) where T : Component
        {
            var comp = go.GetComponent<T>();
            if (comp != null) UnityEngine.Object.Destroy(comp);
        }

        /// <summary>
        /// Cloned NGUI templates occasionally carry duplicate components that
        /// target the same widget (e.g. two UIButtonColor on one button) —
        /// this trims a component list down to the first <paramref name="keep"/> entries.
        /// </summary>
        public static void RemoveExtraComponents<T>(this GameObject go, int keep = 1) where T : Component
        {
            var comps = go.GetComponents<T>();
            for (int i = keep; i < comps.Length; i++)
                UnityEngine.Object.Destroy(comps[i]);
        }
    }

    #endregion

    #region Core factory / helper class

    /// <summary>
    /// Central static helper for creating and wiring up NGUI widgets at runtime.
    /// Call <see cref="Setup"/> once per scene (templates get destroyed on scene
    /// unload, so re-call it after every relevant scene load) before using any
    /// of the Create* methods.
    /// </summary>
    public static class NGUIModHelper
    {
        // ---- Templates, assigned via Setup() ----
        public static GameObject buttonTemplate;
        public static GameObject toggleTemplate;
        public static GameObject inputTemplate;
        public static GameObject panelTemplate;
        public static GameObject multipleButtonTemplate; // a button whose click cycles through a list of options
        public static GameObject dropdownTemplate;        // must contain a UIPopupList somewhere under it

        public static UIAtlas defaultAtlas;
        public static UIFont defaultFont;

        // ---- Cleanup hooks ----
        // Fired right after a template is cloned, so you can strip out whatever
        // game-specific scripts (localization components, the game's own
        // button-controller MonoBehaviours, etc.) got copied along with it.
        public static Action<GameObject> buttonCleanup;
        public static Action<GameObject> toggleCleanup;
        public static Action<GameObject> inputCleanup;
        public static Action<GameObject> panelCleanup;
        public static Action<GameObject> multipleButtonCleanup;
        public static Action<GameObject> dropdownCleanup;

        // ---- Optional localization hooks ----
        // Some games route all UI text through a localization system (e.g. I2
        // Localization) where passing a "key" instead of literal text is
        // expected. Leave both null to just always set literal text directly.
        // If set, CreateButton/CreateLabel/CreateToggle will call
        // hasLocalizationKey(text) first, and if true, call
        // applyLocalizationKey(labelGameObject, text) instead of setting .text directly.
        public static Func<string, bool> hasLocalizationKey;
        public static Action<GameObject, string> applyLocalizationKey;

        /// <summary>Sets a label's text, routing through the localization hooks if configured.</summary>
        public static void SetLabelText(UILabel label, string text)
        {
            if (label == null) return;

            if (hasLocalizationKey != null && applyLocalizationKey != null && hasLocalizationKey(text))
            {
                applyLocalizationKey(label.gameObject, text);
            }
            else
            {
                label.gameObject.RemoveComponent<UILocalize>();
                label.text = text;
            }
        }

        public static void Setup(
            GameObject buttonTemplate,
            GameObject toggleTemplate = null,
            GameObject inputTemplate = null,
            GameObject panelTemplate = null,
            UIAtlas defaultAtlas = null,
            UIFont defaultFont = null,
            GameObject multipleButtonTemplate = null,
            GameObject dropdownTemplate = null)
        {
            NGUIModHelper.buttonTemplate = buttonTemplate;
            NGUIModHelper.toggleTemplate = toggleTemplate;
            NGUIModHelper.inputTemplate = inputTemplate;
            NGUIModHelper.panelTemplate = panelTemplate;
            NGUIModHelper.defaultAtlas = defaultAtlas;
            NGUIModHelper.defaultFont = defaultFont;
            NGUIModHelper.multipleButtonTemplate = multipleButtonTemplate;
            NGUIModHelper.dropdownTemplate = dropdownTemplate;
        }

        // =====================================================================
        // Buttons
        // =====================================================================

        /// <summary>
        /// Clones the configured button template, positions it, sets its label
        /// text and returns a <see cref="UIButtonPatcher"/> you can hang a click
        /// callback off of.
        ///
        /// Looks for the label at "Background/Label" first (the convention used
        /// by most template-based NGUI button prefabs — some templates also
        /// carry a second, unused top-level "Label" that must NOT be touched),
        /// falling back to any descendant named "Label" if that path doesn't exist.
        ///
        /// Also trims cloned templates down to a single UIButtonColor, since
        /// some button prefabs ship with two UIButtonColor components pointed
        /// at the same widget (an artifact of how they were originally built)
        /// which causes flickery/incorrect hover-color behavior if left in place.
        /// </summary>
        public static UIButtonPatcher CreateButton(Transform parent, string text, Vector3 localPosition, Vector2? size = null, string name = "Button", int? depth = null, int? fontSize = null)
        {
            if (buttonTemplate == null)
            {
                Debug.LogError("[NGUIModHelper] buttonTemplate is null — did you forget to call Setup()?");
                return null;
            }

            var (go, label) = InstantiateButtonBase(parent, text, localPosition, size, name, depth, fontSize);

            var patcher = go.AddComponent<UIButtonPatcher>();
            patcher.button = go.GetComponent<UIButton>();
            patcher.buttonLabel = label;

            return patcher;
        }

        /// <summary>
        /// Clones the button template and turns it into a two-state toggle
        /// button instead of a one-shot click button — clicking flips between
        /// <paramref name="uncheckedColor"/> and <paramref name="checkedColor"/>
        /// (defaulting to the button's own normal/hover colors if left null)
        /// and fires <see cref="UIButtonAsToggle.onClick"/> with the new state.
        /// </summary>
        public static UIButtonAsToggle CreateButtonAsToggle(Transform parent, string text, Vector3 localPosition, Vector2? size = null, Color? checkedColor = null, Color? uncheckedColor = null, string name = "ToggleButton")
        {
            if (buttonTemplate == null)
            {
                Debug.LogError("[NGUIModHelper] buttonTemplate is null — did you forget to call Setup()?");
                return null;
            }

            var (go, _) = InstantiateButtonBase(parent, text, localPosition, size, name, null, null);

            var toggle = go.AddComponent<UIButtonAsToggle>();
            var color = go.GetComponent<UIButtonColor>();
            toggle.uncheckedColor = uncheckedColor ?? (color != null ? color.defaultColor : Color.white);
            toggle.checkedColor = checkedColor ?? (color != null ? color.hover : Color.gray);

            return toggle;
        }

        /// <summary>
        /// Clones the button template and turns it into a "multiple choice"
        /// button — each click cycles to the next option in a list, showing
        /// the current one via <see cref="UIButtonMultiple.currentSelectedText"/>.
        /// Reuses the button template rather than <see cref="multipleButtonTemplate"/>
        /// when a dedicated title label isn't needed; use
        /// <see cref="CreateButtonMultipleWithTitle"/> for the title+value two-label layout.
        /// </summary>
        public static UIButtonMultiple CreateButtonMultiple(Transform parent, Vector3 localPosition, Vector2? size = null, string name = "MultipleButton", int? fontSize = null)
        {
            if (buttonTemplate == null)
            {
                Debug.LogError("[NGUIModHelper] buttonTemplate is null — did you forget to call Setup()?");
                return null;
            }

            var (go, label) = InstantiateButtonBase(parent, "", localPosition, size, name, null, fontSize);

            var multi = go.AddComponent<UIButtonMultiple>();
            multi.Init(titleLabel: null, currentOptionLabel: label);
            return multi;
        }

        /// <summary>
        /// Same as <see cref="CreateButtonMultiple"/> but uses the dedicated
        /// <see cref="multipleButtonTemplate"/>, which is expected to carry two
        /// separate labels — a top-level "Label" for a static title, and a
        /// "Background/Label" for the currently selected option.
        /// </summary>
        public static UIButtonMultiple CreateButtonMultipleWithTitle(Transform parent, string title, Vector3 localPosition, Vector3? scale = null, string name = "MultipleButton")
        {
            if (multipleButtonTemplate == null)
            {
                Debug.LogError("[NGUIModHelper] multipleButtonTemplate is null — did you forget to call Setup()?");
                return null;
            }

            GameObject go = UnityEngine.Object.Instantiate(multipleButtonTemplate, parent);
            go.name = name;
            go.transform.localPosition = localPosition;
            go.transform.localScale = scale ?? Vector3.one;

            go.RemoveExtraComponents<UIButtonColor>(keep: 1);
            multipleButtonCleanup?.Invoke(go);

            UILabel titleLabel = go.GetChild("Label")?.GetComponent<UILabel>();
            UILabel currentOptionLabel = go.GetChildAt("Background/Label")?.GetComponent<UILabel>();

            var multi = go.AddComponent<UIButtonMultiple>();
            multi.Init(titleLabel, currentOptionLabel);
            if (titleLabel != null) multi.SetTitle(title);

            return multi;
        }

        /// <summary>
        /// Clones <see cref="dropdownTemplate"/> (which must contain a
        /// UIPopupList — NGUI's native dropdown widget — somewhere under it,
        /// conventionally as its first child) and wraps it for easy option
        /// management.
        /// </summary>
        public static UIDropdownPatcher CreateDropdown(Transform parent, Vector3 localPosition, Vector3? scale = null, string name = "Dropdown")
        {
            if (dropdownTemplate == null)
            {
                Debug.LogError("[NGUIModHelper] dropdownTemplate is null — did you forget to call Setup()?");
                return null;
            }

            GameObject go = UnityEngine.Object.Instantiate(dropdownTemplate, parent);
            go.name = name;
            go.transform.localPosition = localPosition;
            go.transform.localScale = scale ?? Vector3.one;

            dropdownCleanup?.Invoke(go);

            UIPopupList popupList = go.GetComponentInChildren<UIPopupList>();
            if (popupList == null)
            {
                Debug.LogError("[NGUIModHelper] Could not find a UIPopupList anywhere under dropdownTemplate.");
                return null;
            }

            var patcher = go.AddComponent<UIDropdownPatcher>();
            patcher.Init(popupList);
            patcher.ClearOptions();

            return patcher;
        }

        /// <summary>Shared clone+label-setup logic used by CreateButton, CreateButtonAsToggle and CreateButtonMultiple.</summary>
        static (GameObject go, UILabel label) InstantiateButtonBase(Transform parent, string text, Vector3 localPosition, Vector2? size, string name, int? depth, int? fontSize)
        {
            GameObject go = UnityEngine.Object.Instantiate(buttonTemplate, parent);
            go.name = name;
            go.transform.localPosition = localPosition;
            go.transform.localScale = Vector3.one;

            go.RemoveExtraComponents<UIButtonColor>(keep: 1);
            buttonCleanup?.Invoke(go);

            if (size.HasValue) ResizeButton(go, size.Value);
            if (depth.HasValue)
            {
                var bgSprite = go.GetComponent<UISprite>();
                if (bgSprite != null) bgSprite.depth = depth.Value;
            }

            UILabel label = (go.GetChildAt("Background/Label") ?? go.GetChild("Label"))?.GetComponent<UILabel>();
            if (label != null)
            {
                SetLabelText(label, text);
                if (fontSize.HasValue) label.fontSize = fontSize.Value;
                label.SetAnchor(go, 0, 0, 0, 0); // stretch the label to fill the button
            }

            return (go, label);
        }

        /// <summary>Resizes a cloned button's background sprite and its click collider together.</summary>
        public static void ResizeButton(GameObject buttonRoot, Vector2 size)
        {
            var sprite = buttonRoot.GetComponent<UISprite>();
            if (sprite != null)
            {
                sprite.width = Mathf.RoundToInt(size.x);
                sprite.height = Mathf.RoundToInt(size.y);
            }

            var collider = buttonRoot.GetComponent<BoxCollider>();
            if (collider != null)
                collider.size = new Vector3(size.x, size.y, collider.size.z);
        }

        /// <summary>Adds a small icon sprite as a child of an existing widget (e.g. inside a button).</summary>
        public static UISprite AddIcon(GameObject parent, string spriteName, Vector2 size, Vector3 localPosition, int depth = 1, UIAtlas atlas = null)
        {
            var iconGO = new GameObject("Icon");
            iconGO.transform.parent = parent.transform;
            iconGO.transform.localScale = Vector3.one;
            iconGO.transform.localPosition = localPosition;

            var sprite = iconGO.AddComponent<UISprite>();
            sprite.atlas = atlas ?? defaultAtlas;
            sprite.spriteName = spriteName;
            sprite.width = Mathf.RoundToInt(size.x);
            sprite.height = Mathf.RoundToInt(size.y);
            sprite.depth = depth;
            return sprite;
        }

        // =====================================================================
        // Labels
        // =====================================================================

        public static UILabel CreateLabel(
            Transform parent, string text, Vector3 localPosition, Vector2 size,
            NGUIText.Alignment alignment = NGUIText.Alignment.Center,
            UIWidget.Pivot pivot = UIWidget.Pivot.Center,
            int fontSize = 30, UIFont font = null, string name = "Label")
        {
            var go = new GameObject(name);
            go.transform.parent = parent;
            go.transform.localScale = Vector3.one;
            go.transform.localPosition = localPosition;

            var label = go.AddComponent<UILabel>();
            label.bitmapFont = font ?? defaultFont;
            label.width = Mathf.RoundToInt(size.x);
            label.height = Mathf.RoundToInt(size.y);
            label.alignment = alignment;
            label.pivot = pivot;
            label.fontSize = fontSize;
            SetLabelText(label, text);
            return label;
        }

        // =====================================================================
        // Toggles
        // =====================================================================

        public static UITogglePatcher CreateToggle(Transform parent, Vector3 localPosition, bool startState = false, string name = "Toggle")
        {
            if (toggleTemplate == null)
            {
                Debug.LogError("[NGUIModHelper] toggleTemplate is null — did you forget to call Setup()?");
                return null;
            }

            GameObject go = UnityEngine.Object.Instantiate(toggleTemplate, parent);
            go.name = name;
            go.transform.localPosition = localPosition;
            go.transform.localScale = Vector3.one;

            toggleCleanup?.Invoke(go);

            var patcher = go.AddComponent<UITogglePatcher>();
            patcher.Set(startState, executeCallback: false, instant: true);
            return patcher;
        }

        // =====================================================================
        // Input fields
        // =====================================================================

        /// <summary>
        /// Builds a standalone input field from scratch (background sprite +
        /// label + collider + UIInput), rather than cloning a template — input
        /// fields tend to be simple enough, and different enough per-use
        /// (numeric vs. free text), that building fresh is usually less fiddly
        /// than templating one.
        ///
        /// NOTE: this deliberately does NOT wire up character validation for
        /// you. Different NGUI builds expose custom validation differently —
        /// some have a delegate field (commonly named "onValidate", signature
        /// `char (string text, int charIndex, char addedChar)`), others just a
        /// "validation"/"validator" enum (Integer/Float/Alphanumeric/etc.) with
        /// no way to plug in custom logic. Check what your UIInput actually
        /// exposes and wire it up yourself, e.g.:
        ///   var input = NGUIModHelper.CreateInputField(...);
        ///   input.onValidate = NGUIModHelper.ValidateNonNegativeInt; // if your build has this member
        /// The Validate* methods below match the common `(string, int, char) => char` signature.
        /// </summary>
        public static UIInput CreateInputField(
            Transform parent, Vector3 localPosition, Vector2 size,
            string defaultText = "", int fontSize = 27,
            NGUIText.Alignment alignment = NGUIText.Alignment.Left,
            UIAtlas atlas = null, UIFont font = null,
            int depth = 0)
        {
            var go = new GameObject("InputField");
            go.transform.parent = parent;
            go.transform.localPosition = localPosition;
            go.transform.localScale = Vector3.one;

            var bg = go.AddComponent<UISprite>();
            bg.atlas = atlas ?? defaultAtlas;
            bg.spriteName = "Square";
            bg.width = Mathf.RoundToInt(size.x);
            bg.height = Mathf.RoundToInt(size.y);
            bg.depth = depth;

            var labelGO = new GameObject("Text");
            labelGO.transform.parent = go.transform;
            labelGO.transform.localPosition = Vector3.zero;
            labelGO.transform.localScale = Vector3.one;

            var label = labelGO.AddComponent<UILabel>();
            label.bitmapFont = font ?? defaultFont;
            label.fontSize = fontSize;
            label.width = Mathf.RoundToInt(size.x) - 5;
            label.height = Mathf.RoundToInt(size.y);
            label.alignment = alignment;
            label.depth = depth + 1;

            var collider = go.AddComponent<BoxCollider>();
            collider.center = Vector3.zero;
            collider.size = new Vector3(size.x, size.y, 1f);

            var input = go.AddComponent<UIInput>();
            input.label = label;
            input.defaultText = defaultText;
            input.value = defaultText;

            inputCleanup?.Invoke(go);

            return input;
        }

        /// <summary>Only digits and a single decimal point.</summary>
        public static char ValidateNonNegativeFloat(string text, int charIndex, char addedChar)
        {
            if (!char.IsDigit(addedChar) && addedChar != '.') return '\0';
            if (addedChar == '.' && text.Contains(".")) return '\0';
            return addedChar;
        }

        /// <summary>Digits only.</summary>
        public static char ValidateNonNegativeInt(string text, int charIndex, char addedChar)
        {
            return char.IsDigit(addedChar) ? addedChar : '\0';
        }

        /// <summary>Digits, one decimal point, one optional leading minus sign, capped decimal places.</summary>
        public static char ValidateFloatWithMaxDecimals(string text, int charIndex, char addedChar, int maxDecimals)
        {
            if (!char.IsDigit(addedChar) && addedChar != '.' && addedChar != '-') return '\0';

            if (addedChar == '.')
                return text.Contains(".") ? '\0' : addedChar;

            if (addedChar == '-')
                return (text.Contains("-") || charIndex != 0) ? '\0' : addedChar;

            int dotIndex = text.IndexOf('.');
            if (dotIndex != -1 && (text.Length - dotIndex) > maxDecimals) return '\0';

            return addedChar;
        }

        /// <summary>
        /// Turns an existing UILabel into an editable input field on demand —
        /// the classic "click a label to rename it" pattern. Adds a click
        /// collider if the label doesn't already have one, and bakes in a fix
        /// for NGUI's UIInput not always firing OnSubmit on its own.
        /// </summary>
        public static UIInputPatcher MakeLabelEditable(GameObject labelObject, Action<string> onSubmit, Vector2? colliderSize = null)
        {
            if (labelObject.TryGetComponent<UIInputPatcher>(out var existing))
            {
                existing.Select();
                return existing;
            }

            var label = labelObject.GetComponent<UILabel>();
            if (label == null)
            {
                Debug.LogError("[NGUIModHelper] MakeLabelEditable called on an object with no UILabel.");
                return null;
            }

            if (!labelObject.TryGetComponent<BoxCollider>(out var collider))
            {
                collider = labelObject.AddComponent<BoxCollider>();
                var size = colliderSize ?? new Vector2(label.width, label.height);
                collider.size = new Vector3(size.x, size.y, 1f);
            }

            var input = labelObject.AddComponent<UIInput>();
            input.label = label;
            input.value = label.text;

            var patcher = labelObject.AddComponent<UIInputPatcher>();
            patcher.Init(input, onSubmit);
            patcher.Select();

            return patcher;
        }

        // =====================================================================
        // EventDelegate helpers — for wiring into native UIButton.onClick /
        // UIToggle.onChange / UIInput.onSubmit lists owned by the game's own
        // widgets (e.g. its native popups), when you don't control the
        // component and can't just use UIButtonPatcher/UITogglePatcher.
        //
        // These deliberately avoid EventDelegate.Parameter/mParameters —
        // that field is private in stock NGUI (only a read-only, reflection-
        // computed "parameters" getter is public) and isn't guaranteed
        // accessible the same way across different games' NGUI builds.
        // Passing a plain closure sidesteps that entirely: capture whatever
        // data you need directly in the lambda, e.g.
        //   NGUIModHelper.AddClick(someNativeButton, () => DeleteLevel(fileName));
        // =====================================================================

        /// <summary>Appends a callback to a native UIButton's onClick list without wiping existing listeners.</summary>
        public static void AddClick(UIButton button, Action callback)
        {
            EventDelegate.Add(button.onClick, () => callback());
        }

        /// <summary>Appends a callback to a native UIToggle's onChange list without wiping existing listeners.</summary>
        public static void AddChange(UIToggle toggle, Action callback)
        {
            EventDelegate.Add(toggle.onChange, () => callback());
        }

        /// <summary>Appends a callback to a native UIInput's onSubmit list without wiping existing listeners.</summary>
        public static void AddSubmit(UIInput input, Action callback)
        {
            EventDelegate.Add(input.onSubmit, () => callback());
        }

        public static void ClearClicks(UIButton button) => button.onClick.Clear();
        public static void ClearChanges(UIToggle toggle) => toggle.onChange.Clear();

        // =====================================================================
        // Fade helpers (built on NGUI's TweenAlpha)
        // =====================================================================

        public static void FadeIn(GameObject go, float duration = 0.2f, Action onComplete = null)
        {
            go.SetActive(true);
            var tween = TweenAlpha.Begin(go, duration, 1f);
            if (onComplete != null) EventDelegate.Add(tween.onFinished, () => onComplete());
        }

        public static void FadeOut(GameObject go, float duration = 0.2f, bool deactivateOnFinish = true)
        {
            var tween = TweenAlpha.Begin(go, duration, 0f);
            if (deactivateOnFinish)
                EventDelegate.Add(tween.onFinished, () => go.SetActive(false));
        }

        // =====================================================================
        // Dragging
        // =====================================================================

        /// <summary>Makes a window/panel draggable by adding NGUI's own UIDragObject.</summary>
        public static UIDragObject MakeDraggable(GameObject window)
        {
            var drag = window.GetComponent<UIDragObject>() ?? window.AddComponent<UIDragObject>();
            drag.target = window.transform;
            if (window.GetComponent<BoxCollider>() == null)
            {
                // UIDragObject needs something to receive the drag events on.
                var panel = window.GetComponentInChildren<UIPanel>();
                var widget = window.GetComponentInChildren<UIWidget>();
                var size = widget != null ? new Vector3(widget.width, widget.height, 1f) : new Vector3(400, 300, 1f);
                var col = window.AddComponent<BoxCollider>();
                col.size = size;
            }
            return drag;
        }

        // =====================================================================
        // Simple custom popup (fully self-built, doesn't rely on the game's own popup controller)
        // =====================================================================

        public static GameObject CreateSimplePopup(
            Transform parent, string title, string message,
            Action onConfirm, Action onCancel = null,
            string confirmText = "Yes", string cancelText = "No")
        {
            if (panelTemplate == null)
            {
                Debug.LogError("[NGUIModHelper] panelTemplate is null — did you forget to call Setup()?");
                return null;
            }

            GameObject popup = UnityEngine.Object.Instantiate(panelTemplate, parent);
            popup.name = "SimplePopup";
            popup.transform.localPosition = Vector3.zero;
            popup.transform.localScale = Vector3.one;
            panelCleanup?.Invoke(popup);

            CreateLabel(popup.transform, title, new Vector3(0, 120, 0), new Vector2(400, 50), fontSize: 32, name: "Title");
            CreateLabel(popup.transform, message, new Vector3(0, 40, 0), new Vector2(380, 100), fontSize: 24, name: "Message");

            var confirmBtn = CreateButton(popup.transform, confirmText, new Vector3(-90, -80, 0), new Vector2(150, 50), "ConfirmButton");
            if (confirmBtn != null)
            {
                confirmBtn.onClick += () =>
                {
                    onConfirm?.Invoke();
                    UnityEngine.Object.Destroy(popup);
                };
            }

            var cancelBtn = CreateButton(popup.transform, cancelText, new Vector3(90, -80, 0), new Vector2(150, 50), "CancelButton");
            if (cancelBtn != null)
            {
                cancelBtn.onClick += () =>
                {
                    onCancel?.Invoke();
                    UnityEngine.Object.Destroy(popup);
                };
            }

            FadeIn(popup, 0.15f);
            return popup;
        }
    }

    #endregion

    #region Patcher components

    /// <summary>
    /// Attach-and-forget wrapper around a UIButton. Relies on NGUI/UICamera's
    /// generic notification system, which SendMessages "OnClick" to every
    /// component on a clicked collider's GameObject that defines it — so this
    /// works automatically with zero manual EventDelegate wiring.
    /// </summary>
    public class UIButtonPatcher : MonoBehaviour
    {
        public UIButton button;
        public UILabel buttonLabel;
        public UISprite buttonSprite;

        public Action onClick;

        void Awake()
        {
            if (button == null) button = GetComponent<UIButton>();
        }

        void OnDestroy()
        {
            onClick = null;
        }

        // Called automatically by NGUI's UICamera notification system.
        void OnClick()
        {
            onClick?.Invoke();
        }
    }

    /// <summary>
    /// Wrapper around a UIToggle exposing a plain Action&lt;bool&gt; and a
    /// Set() that lets you change state without (or with) firing the callback,
    /// with or without the toggle's tween animation.
    /// </summary>
    public class UITogglePatcher : MonoBehaviour
    {
        UIToggle toggle;
        bool suppressCallback;

        public Action<bool> onClick;
        public bool isChecked => toggle.value;

        void Awake()
        {
            toggle = GetComponent<UIToggle>();
            toggle.onChange.Add(new EventDelegate(this, nameof(OnToggleChange)));
        }

        void OnDestroy()
        {
            onClick = null;
        }

        void OnToggleChange()
        {
            if (suppressCallback) return;
            onClick?.Invoke(toggle.value);
        }

        /// <summary>
        /// Sets the toggle's state. <paramref name="executeCallback"/> controls
        /// whether onClick fires; <paramref name="instant"/> controls whether
        /// the visual tween plays or snaps instantly.
        /// </summary>
        public void Set(bool newState, bool executeCallback = true, bool instant = false)
        {
            suppressCallback = !executeCallback;
            toggle.instantTween = instant;

            if (newState != toggle.value)
            {
                toggle.Set(newState);
            }
            else
            {
                // Set() only fires onChange when the value actually differs —
                // force the visual state and invoke the callback ourselves if asked.
                toggle.activeSprite.alpha = newState ? 1f : 0f;
                toggle.activeSprite.transform.localScale = newState ? Vector3.one : new Vector3(0.1f, 0.1f, 1f);
                if (executeCallback) onClick?.Invoke(newState);
            }

            toggle.instantTween = false;

            // Re-arm the callback shortly after, in case NGUI fires OnToggleChange
            // from somewhere we didn't expect during the SetActive/tween dance.
            Invoke(nameof(ReenableCallback), 0.1f);
        }

        void ReenableCallback() => suppressCallback = false;
    }

    /// <summary>
    /// Wrapper for a UIInput created via <see cref="NGUIModHelper.MakeLabelEditable"/>.
    /// Bakes in a fix for NGUI's UIInput sometimes not firing OnSubmit when the
    /// field loses focus (deselected) without the user pressing Enter.
    /// </summary>
    public class UIInputPatcher : MonoBehaviour
    {
        UIInput input;
        Action<string> onSubmitCallback;
        bool wasSelected;

        public void Init(UIInput input, Action<string> onSubmit)
        {
            this.input = input;
            onSubmitCallback = onSubmit;
            input.onSubmit.Add(new EventDelegate(this, nameof(HandleSubmit)));
        }

        public void Select() => input.isSelected = true;

        void Update()
        {
            if (input == null) return;

            if (input.isSelected) wasSelected = true;

            // Deselected without an explicit Submit having fired yet — force it.
            if (!input.isSelected && wasSelected)
            {
                wasSelected = false;
                input.Submit();
            }
        }

        void HandleSubmit()
        {
            onSubmitCallback?.Invoke(input.value.Trim());
        }
    }

    /// <summary>
    /// Turns a UIButton into a two-state toggle rather than a one-shot click —
    /// each click flips the state and swaps between two colors.
    /// </summary>
    public class UIButtonAsToggle : MonoBehaviour
    {
        UIButton button;

        public bool isChecked { get; private set; }
        public Action<bool> onClick;

        public Color checkedColor = Color.white;
        public Color uncheckedColor = Color.gray;

        void Awake()
        {
            button = GetComponent<UIButton>();
        }

        void OnDestroy()
        {
            onClick = null;
        }

        // Called automatically by NGUI's UICamera notification system.
        void OnClick()
        {
            SetToggleState(!isChecked, executeOnClick: true);
        }

        public void SetToggleState(bool newState, bool executeOnClick = false)
        {
            isChecked = newState;
            if (button != null) button.defaultColor = newState ? checkedColor : uncheckedColor;
            if (executeOnClick) onClick?.Invoke(isChecked);
        }
    }

    /// <summary>
    /// Turns a UIButton into a "multiple choice" control — each click cycles
    /// to the next option in a list and updates a label to show it. Handy for
    /// settings menus (e.g. a "Quality: Low / Medium / High" button).
    /// </summary>
    public class UIButtonMultiple : MonoBehaviour
    {
        UILabel titleLabel;
        UILabel currentOptionLabel;
        readonly List<string> options = new List<string>();

        /// <summary>Fired with the newly selected option's index whenever it changes.</summary>
        public Action<int> onClick;

        /// <summary>
        /// Optional display-text override (e.g. for localization) — return null
        /// for a given index to fall back to the raw option text.
        /// </summary>
        public Func<int, string> displayTextOverride;

        public int currentSelectedID { get; private set; }
        public string currentSelectedText => options.Count > 0 ? options[currentSelectedID] : null;
        public int optionsCount => options.Count;

        public void Init(UILabel titleLabel, UILabel currentOptionLabel)
        {
            this.titleLabel = titleLabel;
            this.currentOptionLabel = currentOptionLabel;
        }

        public void SetTitle(string title)
        {
            if (titleLabel != null) titleLabel.text = title;
        }

        public void ClearOptions()
        {
            options.Clear();
            if (currentOptionLabel != null) currentOptionLabel.text = "";
        }

        public void AddOption(string optionText, bool setAsSelected = false)
        {
            options.Add(optionText);
            if (setAsSelected) SelectOption(options.Count - 1, executeOnChange: false);
        }

        public void SelectOption(int optionID, bool executeOnChange = true)
        {
            if (optionID < 0 || optionID >= options.Count) return;
            currentSelectedID = optionID;

            if (currentOptionLabel != null)
                currentOptionLabel.text = displayTextOverride?.Invoke(optionID) ?? options[optionID];

            if (executeOnChange) onClick?.Invoke(optionID);
        }

        // Called automatically by NGUI's UICamera notification system — cycles to the next option.
        void OnClick()
        {
            if (options.Count == 0) return;

            int next = currentSelectedID + 1;
            if (next > options.Count - 1) next = 0;
            SelectOption(next);
        }

        void OnDestroy()
        {
            options.Clear();
            onClick = null;
            displayTextOverride = null;
        }
    }

    /// <summary>
    /// Wraps an NGUI UIPopupList (the native dropdown widget) with a simpler
    /// option-management API, plus an optional secondary label some dropdown
    /// templates use to display the current selection outside the popup itself.
    /// </summary>
    public class UIDropdownPatcher : MonoBehaviour
    {
        UIPopupList popupList;
        UILabel currentSelectionLabel;

        /// <summary>Fired with the newly selected option's index whenever the selection changes.</summary>
        public Action<int> onChange;

        /// <summary>Optional display-text override (e.g. for localization).</summary>
        public Func<string, string> displayTextOverride;

        public string currentlySelected => popupList.value;
        public int currentlySelectedID => popupList.items.IndexOf(popupList.value);

        public void Init(UIPopupList popupList, UILabel currentSelectionLabel = null)
        {
            this.popupList = popupList;
            this.currentSelectionLabel = currentSelectionLabel;
            popupList.onChange.Add(new EventDelegate(this, nameof(OnDropdownChange)));
        }

        public void ClearOptions()
        {
            popupList.items.Clear();
            popupList.value = null;
        }

        public void AddOption(string option, bool setAsSelected = false)
        {
            popupList.items.Add(option);
            if (setAsSelected) SelectOption(popupList.items.Count - 1);
        }

        public void SelectOption(int optionID) => SelectOption(popupList.items[optionID]);

        public void SelectOption(string optionName)
        {
            popupList.value = optionName;
            if (currentSelectionLabel != null)
                currentSelectionLabel.text = displayTextOverride?.Invoke(optionName) ?? optionName;
        }

        /// <summary>Clears and re-attaches the internal onChange listener — useful if you've added your own listeners you now want gone.</summary>
        public void ResetOnChangeListeners()
        {
            popupList.onChange.Clear();
            popupList.onChange.Add(new EventDelegate(this, nameof(OnDropdownChange)));
        }

        void OnDropdownChange()
        {
            SelectOption(popupList.value);
            onChange?.Invoke(currentlySelectedID);
        }

        void OnDestroy()
        {
            onChange = null;
            displayTextOverride = null;
        }
    }

    #endregion
}